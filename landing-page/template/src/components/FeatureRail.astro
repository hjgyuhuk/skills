---
const features = [
  {
    label: "Entrance",
    title: "Hero elements arrive in a staggered visual rhythm.",
    accent: "bg-cobalt"
  },
  {
    label: "Hover",
    title: "Action targets react with magnetic pointer movement.",
    accent: "bg-coral"
  },
  {
    label: "Scroll",
    title: "Sections reveal only when they become meaningful.",
    accent: "bg-jade"
  }
];
---

<section id="work" class="border-y border-ink/20 bg-paper py-20 md:py-28">
  <div class="shell">
    <div class="mb-12 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="eyebrow mb-4" data-reveal>Interaction stack</p>
        <h2 class="max-w-3xl font-display text-6xl leading-[0.9] md:text-8xl" data-reveal>
          Motion where it earns attention.
        </h2>
      </div>
      <p class="max-w-sm text-sm font-semibold leading-6 text-ink/64" data-reveal>
        Replace the copy and visual blocks with the actual product story. Keep the motion system intact unless the brand calls for a different tempo.
      </p>
    </div>

    <div class="grid gap-px overflow-hidden border border-ink bg-ink md:grid-cols-3">
      {
        features.map((feature, index) => (
          <article class="group min-h-80 bg-paper p-6 transition-colors hover:bg-mist" data-reveal data-magnetic>
            <div class={`mb-16 h-3 w-16 ${feature.accent}`}></div>
            <p class="mb-4 text-xs font-black uppercase text-ink/52">0{index + 1} / {feature.label}</p>
            <h3 class="font-display text-4xl leading-none">{feature.title}</h3>
            <div class="mt-10 h-px w-full bg-ink/15"></div>
            <p class="mt-4 text-sm font-bold text-ink/58">Powered by Motion</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
