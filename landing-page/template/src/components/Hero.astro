---
const navItems = ["Work", "System", "Proof"];
---

<header class="shell flex min-h-20 items-center justify-between py-5">
  <a class="focus-ring flex items-center gap-3 font-extrabold" href="/" aria-label="Signal Works home">
    <span class="grid size-9 place-items-center bg-ink text-paper">S</span>
    <span>Signal Works</span>
  </a>
  <nav class="hidden items-center gap-8 text-sm font-bold md:flex" aria-label="Primary navigation">
    {navItems.map((item) => <a class="focus-ring hover:text-coral" href={`#${item.toLowerCase()}`}>{item}</a>)}
  </nav>
  <a
    class="focus-ring inline-flex h-11 items-center justify-center border border-ink bg-ink px-5 text-sm font-extrabold text-paper transition-colors hover:bg-coral hover:text-ink"
    data-magnetic
    href="#contact"
  >
    Start
  </a>
</header>

<section class="shell grid min-h-[calc(100svh-80px)] grid-cols-1 content-center gap-8 pb-14 pt-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
  <div class="flex flex-col justify-center">
    <p class="eyebrow mb-6" data-hero>Astro / Motion / Lenis</p>
    <h1 class="max-w-5xl font-display text-[clamp(4.6rem,13vw,12rem)] leading-[0.78] tracking-normal" data-hero>
      Build pages that move with intent.
    </h1>
    <div class="mt-8 grid gap-5 border-y border-ink/20 py-6 sm:grid-cols-[1fr_auto] sm:items-center" data-hero>
      <p class="max-w-xl text-balance text-lg font-medium leading-7 text-ink/72">
        A premium landing page skeleton with cinematic entrance motion, scroll reveals, magnetic hover targets, and smooth Lenis scrolling.
      </p>
      <a
        class="focus-ring inline-flex h-14 items-center justify-center bg-jade px-7 text-sm font-black uppercase text-ink shadow-sharp transition-transform hover:-translate-y-1"
        data-magnetic
        href="#work"
      >
        Explore frame
      </a>
    </div>
  </div>

  <div class="relative min-h-[440px] overflow-hidden border border-ink bg-ink text-paper shadow-sharp lg:min-h-[620px]" data-hero>
    <div class="absolute inset-x-0 top-0 z-10 flex items-center justify-between border-b border-paper/15 bg-paper/8 px-4 py-3 text-xs font-black uppercase">
      <span>Live composition</span>
      <span class="text-jade">98.4</span>
    </div>
    <div class="grid h-full grid-rows-[1fr_auto] pt-12">
      <div class="relative isolate overflow-hidden">
        <div class="absolute left-8 top-10 h-32 w-32 border border-paper/25 bg-cobalt"></div>
        <div class="absolute right-10 top-24 h-48 w-28 bg-coral"></div>
        <div class="absolute bottom-16 left-12 right-12 grid grid-cols-4 gap-3">
          <span class="h-24 bg-paper"></span>
          <span class="h-44 bg-jade"></span>
          <span class="h-32 bg-amber"></span>
          <span class="h-56 bg-paper/18"></span>
        </div>
        <div class="absolute inset-x-8 bottom-52 border-t border-paper/20"></div>
        <div class="absolute bottom-24 right-8 max-w-[14rem] text-right font-display text-6xl italic leading-none text-paper">
          signal over noise
        </div>
      </div>
      <div class="grid grid-cols-3 border-t border-paper/15 text-xs font-bold uppercase">
        <span class="p-4 text-paper/62">Frame 01</span>
        <span class="border-x border-paper/15 p-4 text-paper/62">Scroll ready</span>
        <span class="p-4 text-right text-paper/62">Motion safe</span>
      </div>
    </div>
  </div>
</section>
